# ─────────────────────────────────────────────────────────────────────────────
# TATT Management App — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tatt_db
DB_USER=postgres
DB_PASS=dohtech1

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=change_me_to_a_long_random_secret_before_shipping
JWT_EXPIRES_IN=7d

# ─── Security / 2FA ───────────────────────────────────────────────────────────
# Used to encrypt TOTP secrets at rest (AES-256-GCM).
# Must be at least 32 characters. Rotate carefully — changing this invalidates
# all existing TOTP secrets stored in the DB.
# Generate: openssl rand -hex 32
APP_SECRET=change_me_to_a_32plus_char_secret_for_aes256

# ─── Email (SMTP / Nodemailer) ────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM="TATT Platform <no-reply@tatt.org>"
FRONTEND_URL=http://localhost:5173

# ─── Stripe (Billing) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_UBUNTU_MONTHLY=price_...
STRIPE_PRICE_UBUNTU_YEARLY=price_...
STRIPE_PRICE_IMANI_MONTHLY=price_...
STRIPE_PRICE_IMANI_YEARLY=price_...
STRIPE_PRICE_KIONGOZI_MONTHLY=price_...
STRIPE_PRICE_KIONGOZI_YEARLY=price_...

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# ─── API Base URL (used in Swagger "server" dropdown) ────────────────────────
API_BASE_URL=http://localhost:3000

# ─── File Uploads ─────────────────────────────────────────────────────────────
# Absolute or relative path where uploaded files are stored on disk.
# In production, point this to a persistent volume (e.g. /var/tatt/uploads).
UPLOAD_DIR=./uploads
# Base URL the browser uses to fetch uploaded files.
# Must match the server's public hostname. The API serves /uploads/* statically.
UPLOAD_BASE_URL=http://localhost:3000

