# ─────────────────────────────────────────────────────────────────────────────
# TATT Management App — Environment Variables (Example Template)
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000

# ─── Auth & Test Accounts ──────────────────────────────────────────────────
DEFAULT_ADMIN_EMAIL=admin@tatt.org
DEFAULT_ADMIN_PASS=Admin@TATT2024!
DEFAULT_ADMIN_FIRSTNAME=TATT
DEFAULT_ADMIN_LASTNAME=Admin

# Membership Test Users
TEST_USER_FREE_EMAIL=member-free@tatt.org
TEST_USER_FREE_PASS=NewPassword123!
TEST_USER_UBUNTU_EMAIL=member-ubuntu@tatt.org
TEST_USER_UBUNTU_PASS=NewPassword123!
TEST_USER_IMANI_EMAIL=member-imani@tatt.org
TEST_USER_IMANI_PASS=NewPassword123!
TEST_USER_KIONGOZI_EMAIL=member-kiongozi@tatt.org
TEST_USER_KIONGOZI_PASS=NewPassword123!

# Generic Test User
TEST_USER_EMAIL=testuser_network@tatt.org
TEST_USER_PASSWORD=NewPassword123!

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tatt_db
DB_USER=postgres
DB_PASS=password

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ─── Security / 2FA ───────────────────────────────────────────────────────────
# Used to encrypt TOTP secrets at rest (AES-256-GCM).
# Must be at least 32 characters.
# Generate: openssl rand -hex 32
APP_SECRET=your_32_char_app_secret_here

# ─── Email (SMTP / Nodemailer) ────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM="TATT Platform <no-reply@tatt.org>"
FRONTEND_URL=http://localhost:5173

# ─── Stripe (Billing) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_UBUNTU_MONTHLY=price_...
STRIPE_PRICE_UBUNTU_YEARLY=price_...
STRIPE_PRICE_IMANI_MONTHLY=price_...
STRIPE_PRICE_IMANI_YEARLY=price_...
STRIPE_PRICE_KIONGOZI_MONTHLY=price_...
STRIPE_PRICE_KIONGOZI_YEARLY=price_...

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ─── API Base URL ─────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:3000

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=http://localhost:3000
